# Base URL of the BotThisSite FastAPI app on Nest (no trailing slash).
FASTAPI_BASE_URL=https://bts.zzz.hackclub.app

# Shared secret. Must match BOTID_SHARED_SECRET in the FastAPI app's .env.
# Used in the X-BotID-Secret header so only this shim can record solves.
BOTID_SHARED_SECRET=change-me-to-a-long-random-string
